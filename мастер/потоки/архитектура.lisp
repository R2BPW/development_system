;;; -*- Mode: Lisp; Coding: utf-8 -*-
;;; Имя: архитектура
;;; Описание: Поток-исследование для архитектурных решений.
;;;           Серия уточняющих вопросов → схема подключения + распиновка + выбор компонентов.
;;;           Каждый подзапрос переключает фокус, но не сбрасывает контекст.

(defpackage :поток-архитектура
  (:use :cl)
  (:export #:выполнить))

(in-package :поток-архитектура)

(ql:quickload '("dexador" "cl-json") :silent t)

(defparameter *модель* "openai/gpt-4.1")
(defparameter *макс-шагов* 6)

(defparameter *промпт-системы*
  "Ты архитектор аппаратных и программных систем. Тебе дают описание системы.
Твоя задача — через серию уточнений дойти до конкретной архитектуры.

На каждом шаге:
1. Зафиксируй решения принятые на предыдущих шагах
2. Определи следующий аспект для уточнения (интерфейс, протокол, компонент, распиновка)
3. Предложи конкретный вариант с обоснованием

Форматируй решения структурно:
- Компоненты: название, модель, назначение
- Интерфейсы: протокол, пины, скорость
- Подключения: откуда → куда, через что

Когда архитектура полна, начни ответ словом «АРХИТЕКТУРА:» и дай финальную схему.
Не используй ASCII-art. Описывай текстом: A.PIN_X → B.PIN_Y через ПРОТОКОЛ.")

(defun ключ-апи ()
  (or (sb-ext:posix-getenv "OPENROUTER_API_KEY") (error "OPENROUTER_API_KEY не задан")))

(defun %запросить (сообщения)
  (handler-case
      (let* ((тело (cl-json:encode-json-to-string
                    `((:model . ,*модель*)
                      (:messages . ,(coerce сообщения 'vector)))))
             (сырой (dexador:post "https://openrouter.ai/api/v1/chat/completions"
                       :content тело
                       :headers `(("Content-Type" . "application/json")
                                  ("Authorization" . ,(format nil "Bearer ~a" (ключ-апи))))
                       :read-timeout 120 :connect-timeout 30))
             (json (cl-json:decode-json-from-string
                    (if (stringp сырой) сырой
                        (sb-ext:octets-to-string сырой :external-format :utf-8)))))
        (or (cdr (assoc :content (cdr (assoc :message (first (cdr (assoc :choices json)))))))
            ""))
    (error (e) (format nil "Ошибка LLM: ~a" e))))

(defun %архитектура? (ответ)
  (and (> (length ответ) 20)
       (search "АРХИТЕКТУРА:" ответ)))

(defun %извлечь-архитектуру (ответ)
  (let ((поз (search "АРХИТЕКТУРА:" ответ)))
    (if поз
        (string-trim '(#\Space #\Newline) (subseq ответ (+ поз 12)))
        ответ)))

(defun %шаг (описание история шаг)
  "Рекурсивный шаг проектирования. Контекст накапливается."
  (if (> шаг *макс-шагов*)
      (let ((последний (cdr (assoc :content (car (last история))))))
        (format nil "Проектирование не завершено за ~a шагов.~%Текущее состояние:~%~a"
                *макс-шагов* последний))
      (let* ((запрос (if (= шаг 1)
                         (format nil "Спроектируй архитектуру: ~a" описание)
                         (format nil "Продолжай проектирование. Шаг ~a/~a. Уточни следующий аспект." шаг *макс-шагов*)))
             (новые (append история (list `((:role . "user") (:content . ,запрос)))))
             (ответ (%запросить новые)))
        (if (%архитектура? ответ)
            (%извлечь-архитектуру ответ)
            (%шаг описание
                  (append новые (list `((:role . "assistant") (:content . ,ответ))))
                  (1+ шаг))))))

(defun выполнить (задача)
  "Точка входа. Итеративное проектирование архитектуры.
   Вход: описание системы. Выход: схема + распиновка + компоненты."
  (handler-case
      (let ((история (list `((:role . "system") (:content . ,*промпт-системы*)))))
        (%шаг задача история 1))
    (error (e) (format nil "Ошибка: ~a" e))))
