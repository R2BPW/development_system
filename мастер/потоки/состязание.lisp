;;; -*- Mode: Lisp; Coding: utf-8 -*-
;;; Имя: состязание
;;; Описание: Поток-состязание — порождает два варианта одного потока через разные
;;;           модели, прогоняет тестовые входы, сравнивает через LLM-судью, выбирает
;;;           победителя. Проигравший удаляется из образа.

(defpackage :поток-состязание
  (:use :cl)
  (:export #:выполнить))

(in-package :поток-состязание)

(ql:quickload '("dexador" "cl-json") :silent t)

;;; ═══════════════════════════════════════════════════════════════
;;; Конфигурация
;;; ═══════════════════════════════════════════════════════════════

(defparameter *каталог*
  (or (sb-ext:posix-getenv "STREAMS_DIR")
      (namestring (uiop:pathname-directory-pathname *load-truename*))))

(defparameter *модель-а* "openai/gpt-4.1")
(defparameter *модель-б* "google/gemini-2.0-flash-001")
(defparameter *модель-судья* "anthropic/claude-sonnet-4-20250514")

(defparameter *промпт-генерации*
  "Ты генератор Common Lisp потоков. Верни ТОЛЬКО код, без markdown, без ```.
Требования:
- Первая строка: (defpackage :поток-ИМЯ (:use :cl) (:export #:выполнить))
- Вторая строка: (in-package :поток-ИМЯ)
- (defun выполнить (задача) ...) — единственная точка входа, возвращает строку
- HTTP через dexador (уже загружен): (dexador:post url :headers ... :content ...)
  dexador возвращает строку или байты — преобразуй: (if (stringp r) r (sb-ext:octets-to-string r :external-format :utf-8))
- JSON через cl-json (уже загружен): encode-json-to-string, decode-json-from-string
- OPENROUTER_API_KEY через (sb-ext:posix-getenv \"OPENROUTER_API_KEY\")
- OpenRouter URL: https://openrouter.ai/api/v1/chat/completions
- handler-case вместо restart-case
- рекурсия вместо loop, функции до 15 строк, без CLOS
- НЕ использовать drakma, flexi-streams, split-sequence — их нет в образе
- НЕ использовать квадратные скобки [] — это не CL синтаксис")

(defparameter *промпт-судьи*
  "Ты объективный судья кода. Тебе даны два варианта реализации одного потока
и результаты тестов обоих вариантов.

Оцени по критериям:
1. Корректность: оба скомпилировались? тесты прошли?
2. Качество кода: читаемость, идиоматичность CL, краткость
3. Устойчивость: handler-case на границах, обработка крайних случаев
4. Результат: качество выхода на тестовых входах

Формат ответа:
ПОБЕДИТЕЛЬ: А | Б | НИЧЬЯ
СЧЁТ: <А:Б> (по 10-балльной шкале каждому)
ПРИЧИНА: <2-3 предложения>")

;;; ═══════════════════════════════════════════════════════════════
;;; LLM-запросы
;;; ═══════════════════════════════════════════════════════════════

(defun ключ-апи ()
  (or (sb-ext:posix-getenv "OPENROUTER_API_KEY") (error "OPENROUTER_API_KEY не задан")))

(defun %запросить (модель системный пользовательский)
  "Универсальный запрос к LLM."
  (handler-case
      (let* ((тело (cl-json:encode-json-to-string
                    `((:model . ,модель)
                      (:messages . #(((:role . "system") (:content . ,системный))
                                     ((:role . "user") (:content . ,пользовательский)))))))
             (сырой (dexador:post "https://openrouter.ai/api/v1/chat/completions"
                       :content тело
                       :headers `(("Content-Type" . "application/json")
                                  ("Authorization" . ,(format nil "Bearer ~a" (ключ-апи))))
                       :read-timeout 90 :connect-timeout 30))
             (json (cl-json:decode-json-from-string
                    (if (stringp сырой) сырой
                        (sb-ext:octets-to-string сырой :external-format :utf-8)))))
        (or (cdr (assoc :content (cdr (assoc :message (first (cdr (assoc :choices json)))))))
            ""))
    (error (e) (format nil "Ошибка LLM (~a): ~a" модель e))))

;;; ═══════════════════════════════════════════════════════════════
;;; Генерация кандидатов
;;; ═══════════════════════════════════════════════════════════════

(defun %извлечь-код (текст)
  "Убирает ```-обёртку если LLM добавил."
  (let* ((start (search "```" текст))
         (code-start (when start (position #\Newline текст :start start)))
         (end (when code-start (search "```" текст :start2 (1+ code-start)))))
    (if (and code-start end)
        (string-trim '(#\Newline #\Space) (subseq текст (1+ code-start) end))
        текст)))

(defun %имя-пакета (код)
  (let* ((метка "поток-") (поз (search метка код)))
    (if (null поз) "безымянный"
        (let* ((нач (+ поз (length метка)))
               (кон (or (position-if
                         (lambda (c) (member c '(#\Space #\Newline #\( #\) #\")))
                         код :start нач)
                        (length код))))
          (subseq код нач кон)))))

(defun %подставить-суффикс (код суффикс)
  "Заменить имя пакета: поток-Х → поток-Х-а или поток-Х-б."
  (let* ((метка "поток-")
         (поз (search метка код)))
    (if (null поз) код
        (let* ((нач (+ поз (length метка)))
               (кон (or (position-if
                         (lambda (c) (member c '(#\Space #\Newline #\( #\) #\")))
                         код :start нач)
                        (length код)))
               (базовое-имя (subseq код нач кон))
               (новое-имя (format nil "~a-~a" базовое-имя суффикс)))
          ;; Заменить все вхождения старого имени на новое
          (%заменить-все код
                        (format nil "поток-~a" базовое-имя)
                        (format nil "поток-~a" новое-имя))))))

(defun %заменить-все (строка что чем)
  "Рекурсивная замена всех вхождений."
  (let ((поз (search что строка)))
    (if (null поз) строка
        (concatenate 'string
                     (subseq строка 0 поз)
                     чем
                     (%заменить-все (subseq строка (+ поз (length что))) что чем)))))

(defun %генерировать (модель описание суффикс)
  "Сгенерировать кандидата: код с уникальным именем пакета."
  (let* ((сырой (%запросить модель *промпт-генерации*
                             (format nil "Создай поток: ~a" описание)))
         (код (%извлечь-код сырой))
         (код-с-суффиксом (%подставить-суффикс код суффикс)))
    код-с-суффиксом))

;;; ═══════════════════════════════════════════════════════════════
;;; Компиляция и загрузка
;;; ═══════════════════════════════════════════════════════════════

(defun %записать (имя код)
  (let ((путь (format nil "~a~a.lisp" *каталог* имя)))
    (with-open-file (f путь :direction :output :if-exists :supersede :external-format :utf-8)
      (write-string код f))
    путь))

(defun %компилировать-и-загрузить (путь)
  "compile-file + load. Возвращает t при успехе."
  (handler-case
      (let ((ok (multiple-value-bind (_ w fail)
                    (compile-file путь :print nil :verbose nil)
                  (declare (ignore _ w)) (not fail))))
        (when ok (load путь :verbose nil :print nil))
        ok)
    (error () nil)))

;;; ═══════════════════════════════════════════════════════════════
;;; Тестирование
;;; ═══════════════════════════════════════════════════════════════

(defun %тестовые-входы (описание)
  "Сгенерировать тестовые входы через LLM."
  (let ((ответ (%запросить *модель-судья*
                "Ты генератор тестов. Дай ровно 3 тестовых входа для потока, каждый на отдельной строке.
Только входные строки, без нумерации, без пояснений."
                (format nil "Поток: ~a" описание))))
    (remove-if (lambda (s) (zerop (length (string-trim '(#\Space) s))))
               (uiop:split-string ответ :separator '(#\Newline)))))

(defun %выполнить-кандидата (имя-пакета вход)
  "Найти ВЫПОЛНИТЬ в пакете, вызвать. Возвращает строку-результат или ошибку."
  (handler-case
      (let* ((pkg (find-package (string-upcase имя-пакета)))
             (sym (when pkg (find-symbol "ВЫПОЛНИТЬ" pkg)))
             (fn (when (and sym (fboundp sym)) (symbol-function sym))))
        (if fn
            (let ((рез (funcall fn вход)))
              (if (stringp рез) рез (format nil "~a" рез)))
            (format nil "ОШИБКА: функция не найдена в ~a" имя-пакета)))
    (error (e) (format nil "ОШИБКА: ~a" e))))

(defun %прогнать-тесты (имя-пакета входы)
  "Прогнать список входов → список (вход . выход)."
  (mapcar (lambda (вход)
            (cons вход (%выполнить-кандидата имя-пакета вход)))
          входы))

;;; ═══════════════════════════════════════════════════════════════
;;; Судейство
;;; ═══════════════════════════════════════════════════════════════

(defun %форматировать-тесты (результаты)
  (format nil "~{~a~^~%~}"
          (mapcar (lambda (пара)
                    (format nil "  Вход: ~a~%  Выход: ~a" (car пара) (cdr пара)))
                  результаты)))

(defun %судить (описание код-а код-б тесты-а тесты-б комп-а комп-б)
  "Попросить LLM-судью выбрать победителя."
  (%запросить *модель-судья* *промпт-судьи*
   (format nil "Задача: ~a~%~%~
--- Вариант А (модель: ~a, компиляция: ~a) ---~%~a~%~%~
Тесты А:~%~a~%~%~
--- Вариант Б (модель: ~a, компиляция: ~a) ---~%~a~%~%~
Тесты Б:~%~a"
           описание
           *модель-а* (if комп-а "OK" "FAIL") код-а (%форматировать-тесты тесты-а)
           *модель-б* (if комп-б "OK" "FAIL") код-б (%форматировать-тесты тесты-б))))

(defun %извлечь-победителя (вердикт)
  "Из текста судьи → :а, :б или :ничья."
  (let ((поз (search "ПОБЕДИТЕЛЬ:" вердикт)))
    (if (null поз) :ничья
        (let ((фрагмент (string-upcase (subseq вердикт (+ поз 11)
                                                (min (+ поз 30) (length вердикт))))))
          (cond
            ((search "А" фрагмент) :а)
            ((search "Б" фрагмент) :б)
            (t :ничья))))))

;;; ═══════════════════════════════════════════════════════════════
;;; Финализация
;;; ═══════════════════════════════════════════════════════════════

(defun %переименовать-победителя (код-победителя базовое-имя суффикс)
  "Убрать суффикс из кода победителя → чистое имя."
  (%заменить-все код-победителя
                 (format nil "поток-~a-~a" базовое-имя суффикс)
                 (format nil "поток-~a" базовое-имя)))

(defun %удалить-файл (имя)
  (let ((путь (format nil "~a~a.lisp" *каталог* имя)))
    (when (probe-file путь) (delete-file путь))))

;;; ═══════════════════════════════════════════════════════════════
;;; Точка входа
;;; ═══════════════════════════════════════════════════════════════

(defun выполнить (задача)
  "Точка входа. Порождает два варианта, тестирует, выбирает лучший.
   Вход: описание потока. Выход: отчёт о состязании + победитель в образе."
  (handler-case
      (let* (;; 1. Генерация
             (код-а (%генерировать *модель-а* задача "а"))
             (код-б (%генерировать *модель-б* задача "б"))
             (имя-базовое (%имя-пакета код-а))
             ;; исправить: имя может содержать суффикс
             (имя-базовое (let ((поз (search "-а" имя-базовое :from-end t)))
                            (if поз (subseq имя-базовое 0 поз) имя-базовое)))
             (имя-а (format nil "~a-а" имя-базовое))
             (имя-б (format nil "~a-б" имя-базовое))
             (пакет-а (format nil "поток-~a" имя-а))
             (пакет-б (format nil "поток-~a" имя-б))

             ;; 2. Запись и компиляция
             (путь-а (%записать имя-а код-а))
             (путь-б (%записать имя-б код-б))
             (комп-а (%компилировать-и-загрузить путь-а))
             (комп-б (%компилировать-и-загрузить путь-б))

             ;; 3. Тестирование
             (входы (%тестовые-входы задача))
             (тесты-а (if комп-а (%прогнать-тесты пакет-а входы) '(("—" . "не скомпилирован"))))
             (тесты-б (if комп-б (%прогнать-тесты пакет-б входы) '(("—" . "не скомпилирован"))))

             ;; 4. Судейство
             (вердикт (%судить задача код-а код-б тесты-а тесты-б комп-а комп-б))
             (победитель (%извлечь-победителя вердикт)))

        ;; 5. Финализация: победитель → чистое имя, проигравший → удалить
        (case победитель
          (:а
           (let* ((чистый-код (%переименовать-победителя код-а имя-базовое "а"))
                  (путь (%записать имя-базовое чистый-код)))
             (%компилировать-и-загрузить путь)
             (%удалить-файл имя-а)
             (%удалить-файл имя-б)))
          (:б
           (let* ((чистый-код (%переименовать-победителя код-б имя-базовое "б"))
                  (путь (%записать имя-базовое чистый-код)))
             (%компилировать-и-загрузить путь)
             (%удалить-файл имя-а)
             (%удалить-файл имя-б)))
          (t ; ничья — оставить вариант А как дефолт
           (let* ((чистый-код (%переименовать-победителя код-а имя-базовое "а"))
                  (путь (%записать имя-базовое чистый-код)))
             (%компилировать-и-загрузить путь)
             (%удалить-файл имя-а)
             (%удалить-файл имя-б))))

        (format nil "⚔️ Состязание «~a»~%~
Модель А: ~a (~a)~%~
Модель Б: ~a (~a)~%~
Тестов: ~a~%~%~
~a~%~%~
Победитель: ~a → сохранён как поток-~a"
                имя-базовое
                *модель-а* (if комп-а "OK" "FAIL")
                *модель-б* (if комп-б "OK" "FAIL")
                (length входы)
                вердикт
                (case победитель (:а "А") (:б "Б") (t "ничья (А по умолчанию)"))
                имя-базовое))
    (error (e) (format nil "Ошибка состязания: ~a" e))))
