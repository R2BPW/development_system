;;; -*- Mode: Lisp; Coding: utf-8 -*-
;;; Имя: размышление
;;; Описание: Поток «глубоко подумай» — использует extended thinking (бюджет на рассуждение)
;;;           для задач, где нужен анализ второго порядка: декомпозиция неочевидных проблем,
;;;           ревью архитектурных решений, формальная верификация логики, анализ каскадных отказов.
;;;           Возвращает структурированную формулировку + список подзадач для других потоков.

(defpackage :поток-размышление
  (:use :cl)
  (:export #:выполнить))

(in-package :поток-размышление)

(ql:quickload '("dexador" "cl-json") :silent t)

;;; ═══════════════════════════════════════════════════════════════
;;; Конфигурация
;;; ═══════════════════════════════════════════════════════════════

;;; Модель с extended thinking. Claude Sonnet 4.5 — хороший баланс
;;; цены и глубины рассуждения. Можно заменить на claude-opus-4.5
;;; для более сложных задач.
(defparameter *модель* "anthropic/claude-sonnet-4-20250514")

;;; Бюджет на рассуждение — в токенах. 10000 — умеренное размышление,
;;; 30000 — глубокое, 60000 — максимальное для большинства задач.
(defparameter *бюджет-размышления* 10000)

;;; max_tokens должен быть строго больше бюджета рассуждения,
;;; чтобы остались токены на финальный ответ.
(defparameter *макс-токенов* 16000)

(defparameter *промпт-системы*
  "Ты аналитик, который глубоко думает перед ответом.

Твоя задача — принять размытую или сложную проблему и вернуть:

1. ФОРМУЛИРОВКА: точное, однозначное описание проблемы (2-3 предложения)

2. КОНТЕКСТ: что нужно знать для решения — скрытые предположения,
   ограничения, зависимости, которые автор мог не упомянуть

3. ГИПОТЕЗЫ: 2-4 возможных направления решения, для каждого:
   - суть подхода
   - что он предполагает
   - чем рискуем

4. ПОДЗАДАЧИ: конкретные задачи для выполнения, каждая в формате:
   - Описание: <что сделать>
   - Тип потока: <аудит|исследование|архитектура|план|документация|исполнитель>
   - Вход: <строка, которую передать потоку>
   - Почему: <как эта подзадача приближает к решению>

5. ПОРЯДОК: в каком порядке выполнять подзадачи, какие можно параллельно

6. СЛЕПЫЕ ЗОНЫ: что ты мог не учесть, о чём стоит спросить

Не генерируй код. Не давай поверхностных ответов. Думай глубоко.
Лучше одна точная мысль, чем десять банальных.")

;;; ═══════════════════════════════════════════════════════════════
;;; LLM-запрос с extended thinking
;;; ═══════════════════════════════════════════════════════════════

(defun ключ-апи ()
  (or (sb-ext:posix-getenv "OPENROUTER_API_KEY") (error "OPENROUTER_API_KEY не задан")))

(defun %тело-запроса (задача)
  "Собрать JSON с параметром reasoning для extended thinking."
  (cl-json:encode-json-to-string
   `((:model . ,*модель*)
     (:max--tokens . ,*макс-токенов*)
     (:reasoning . ((:max--tokens . ,*бюджет-размышления*)))
     (:messages . #(((:role . "system") (:content . ,*промпт-системы*))
                    ((:role . "user") (:content . ,задача)))))))

(defun %запросить (задача)
  "Отправить запрос с extended thinking → строка-ответ."
  (handler-case
      (let* ((сырой (dexador:post "https://openrouter.ai/api/v1/chat/completions"
                       :content (%тело-запроса задача)
                       :headers `(("Content-Type" . "application/json")
                                  ("Authorization" . ,(format nil "Bearer ~a" (ключ-апи))))
                       :read-timeout 300 :connect-timeout 30))
             (текст (if (stringp сырой) сырой
                        (sb-ext:octets-to-string сырой :external-format :utf-8)))
             (json (cl-json:decode-json-from-string текст))
             (сообщение (cdr (assoc :message (first (cdr (assoc :choices json))))))
             (контент (cdr (assoc :content сообщение)))
             (reasoning (cdr (assoc :reasoning сообщение)))
             ;; Токены для отчёта
             (usage (cdr (assoc :usage json)))
             (reasoning-tokens (or (cdr (assoc :reasoning--tokens
                                               (cdr (assoc :completion--tokens--details usage))))
                                   0)))
        (values (or контент "[нет ответа]")
                reasoning
                reasoning-tokens))
    (error (e) (values (format nil "Ошибка LLM: ~a" e) nil 0))))

;;; ═══════════════════════════════════════════════════════════════
;;; Обогащение контекста
;;; ═══════════════════════════════════════════════════════════════

(defun %это-путь? (строка)
  "Проверить, похоже ли на путь к файлу/каталогу."
  (and (> (length строка) 1)
       (char= (char строка 0) #\/)))

(defun %собрать-контекст-репо (путь)
  "Если путь — каталог, собрать структуру для анализа."
  (handler-case
      (let ((дерево (uiop:run-program
                     (list "find" путь "-maxdepth" "3" "-type" "f"
                           "(" "-name" "*.lisp" "-o" "-name" "*.scm"
                           "-o" "-name" "*.py" "-o" "-name" "*.sh"
                           "-o" "-name" "*.md" ")")
                     :output :string :error-output nil
                     :ignore-error-status t)))
        (format nil "~%~%Структура проекта (~a):~%~a" путь дерево))
    (error () "")))

(defun %обогатить-задачу (задача)
  "Если в задаче есть путь — добавить контекст файловой системы."
  (let* ((слова (uiop:split-string задача :separator '(#\Space)))
         (пути (remove-if-not #'%это-путь? слова))
         (контекст (format nil "~{~a~}" (mapcar #'%собрать-контекст-репо пути))))
    (if (zerop (length контекст))
        задача
        (format nil "~a~a" задача контекст))))

;;; ═══════════════════════════════════════════════════════════════
;;; Точка входа
;;; ═══════════════════════════════════════════════════════════════

(defun выполнить (задача)
  "Точка входа. Глубокое размышление над задачей.
   Вход: размытая проблема, вопрос, описание ситуации.
   Выход: формулировка + гипотезы + подзадачи для других потоков."
  (handler-case
      (let ((обогащённая (%обогатить-задачу задача)))
        (multiple-value-bind (ответ reasoning токены) (%запросить обогащённая)
          (format nil "~a~%~%---~%🧠 Затрачено на размышление: ~a токенов~a"
                  ответ токены
                  (if reasoning
                      (format nil "~%~%Цепочка рассуждений доступна (скрыта)")
                      ""))))
    (error (e) (format nil "Ошибка размышления: ~a" e))))
