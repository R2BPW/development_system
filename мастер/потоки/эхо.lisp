;;; -*- Mode: Lisp; Syntax: Common-Lisp -*-
;;; Имя: эхо
;;; Описание: Простейший поток — возвращает входную задачу без изменений

(defpackage :поток-эхо (:use :cl) (:export #:выполнить))
(in-package :поток-эхо)

(defun выполнить (задача)
  "Точка входа. Возвращает задачу как есть."
  (format nil "Эхо: ~a" задача))
