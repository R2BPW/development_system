(in-package #:мастер)

(defun %душа-значение (душа ключ)
  "Извлекает значение из структуры души.
   Формат: (душа (ключ значение) (ключ значение) ...) — alist-подобный."
  (let ((пара (assoc ключ (rest душа))))
    (when пара (second пара))))

(defun читать-душу (путь)
  "Читает файл души из пути. Формат файла: (душа (ключ значение) ...)."
  (let ((данные (with-open-file (in путь :direction :input)
                  (read in))))
    (unless (and (listp данные) (eql (first данные) 'душа))
      (error "Неверный формат файла души: ~A" путь))
    данные))

(defun писать-душу (душа путь)
  "Сохраняет структуру души в путь как read-able S-expression."
  (with-open-file (out путь :direction :output :if-exists :supersede :if-does-not-exist :create)
    (let ((*print-pretty* t))
      (prin1 душа out))))

(defun душа->системный-промпт (душа)
  "Формирует системный промпт из структуры души."
  (let ((указание (%душа-значение душа 'указание))
        (девиз    (%душа-значение душа 'девиз)))
    (format nil "~A~@[~%Стиль: ~A~]" (or указание "") девиз)))
