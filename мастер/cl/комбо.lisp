(in-package #:мастер)

;; Комбинировать потоки: последовательное и параллельное выполнение

(defun комбинировать (потоки задача &key параллельно)
  "Выполнить POTOKI (список имён) над ЗАДАЧЕЙ. Если :параллельно — списком, иначе последовательная передача (выход=вход)."
  (cond
    (параллельно
     (mapconcat #'identity
                (mapcar (lambda (имя)
                          (ignore-errors
                            (запустить-поток имя задача)))
                        потоки)
                "\n---\n"))
    (t
     (let ((in задача)
           (out nil))
       (dolist (имя потоки (or out ""))
         (setf out (ignore-errors (запустить-поток имя in)))
         (setf in out)))
     out)))
