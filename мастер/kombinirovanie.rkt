#lang racket/base

;;; Комбинирование — создание составных потоков из существующих
;;; Последовательные цепочки, параллельное выполнение, условное ветвление

(require racket/file
         racket/format
         racket/list
         racket/path
         racket/string
         "potoki.rkt"
         "dusha.rkt")

(provide создать-цепочку
         создать-параллель
         создать-ветвление
         комбинировать-через-клод
         шаблон-цепочки
         шаблон-параллели
         шаблон-ветвления
         собрать-пути-потоков)

;; --- сбор путей потоков по именам ---

(define (собрать-пути-потоков каталог имена)
  (for/list ([имя (in-list имена)])
    (let ((поток (найти-поток каталог имя)))
      (if поток
          (cons имя (path->string (first поток)))
          (error 'собрать-пути-потоков
                 "Поток ~a не найден" имя)))))

;; --- шаблон: последовательная цепочка ---

(define (шаблон-цепочки имя-комб пары-имя-путь)
  (let ((загрузки
         (string-join
          (for/list ([п (in-list пары-имя-путь)])
            (format "(load ~s :verbose nil :print nil)" (cdr п)))
          "\n"))
        (вызовы
         (let строй ([ост пары-имя-путь] [перем "задача"])
           (if (null? ост)
               перем
               (let ((пакет (format "поток-~a" (car (car ост)))))
                 (строй (cdr ост)
                        (format "(funcall (symbol-function (find-symbol \"ВЫПОЛНИТЬ\" (find-package (string-upcase ~s)))) ~a)"
                                пакет перем)))))))
    (string-append
     ";;; -*- Mode: Lisp; Syntax: Common-Lisp -*-\n"
     ";;; Имя: " имя-комб "\n"
     ";;; Описание: Цепочка потоков — "
     (string-join (map car пары-имя-путь) " → ") "\n"
     "\n"
     "(defpackage :поток-" имя-комб " (:use :cl))\n"
     "(in-package :поток-" имя-комб ")\n"
     "\n"
     ";;; --- загрузка подпотоков ---\n"
     загрузки "\n"
     "\n"
     ";;; --- точка входа ---\n"
     "(defun выполнить (задача)\n"
     "  \"Цепочка: выход одного — вход другого.\"\n"
     "  " вызовы ")\n")))

;; --- шаблон: параллельное выполнение ---

(define (шаблон-параллели имя-комб пары-имя-путь)
  (let ((загрузки
         (string-join
          (for/list ([п (in-list пары-имя-путь)])
            (format "(load ~s :verbose nil :print nil)" (cdr п)))
          "\n"))
        (привязки
         (string-join
          (for/list ([п (in-list пары-имя-путь)]
                     [и (in-naturals)])
            (let ((пакет (format "поток-~a" (car п))))
              (format "(р~a (funcall (symbol-function (find-symbol \"ВЫПОЛНИТЬ\" (find-package (string-upcase ~s)))) задача))"
                      и пакет)))
          "\n         "))
        (слияние
         (string-join
          (for/list ([п (in-list пары-имя-путь)]
                     [и (in-naturals)])
            (format "(format nil \"[~a] ~~a\" р~a)" (car п) и))
          "\n                  ")))
    (string-append
     ";;; -*- Mode: Lisp; Syntax: Common-Lisp -*-\n"
     ";;; Имя: " имя-комб "\n"
     ";;; Описание: Параллель потоков — "
     (string-join (map car пары-имя-путь) " | ") "\n"
     "\n"
     "(defpackage :поток-" имя-комб " (:use :cl))\n"
     "(in-package :поток-" имя-комб ")\n"
     "\n"
     ";;; --- загрузка подпотоков ---\n"
     загрузки "\n"
     "\n"
     ";;; --- точка входа ---\n"
     "(defun выполнить (задача)\n"
     "  \"Параллель: все потоки получают одну задачу, ответы сливаются.\"\n"
     "  (let* (" привязки ")\n"
     "    (format nil \"~{~a~^~%~}\"\n"
     "            (list " слияние "))))\n")))

;; --- шаблон: условное ветвление ---

(define (шаблон-ветвления имя-комб пары-условие-имя-путь)
  (let ((загрузки
         (string-join
          (for/list ([п (in-list пары-условие-имя-путь)])
            (format "(load ~s :verbose nil :print nil)" (third п)))
          "\n"))
        (ветви
         (string-join
          (for/list ([п (in-list пары-условие-имя-путь)])
            (let ((условие (first п))
                  (пакет (format "поток-~a" (second п))))
              (format "((search ~s задача)\n       (funcall (symbol-function (find-symbol \"ВЫПОЛНИТЬ\" (find-package (string-upcase ~s)))) задача))"
                      условие пакет)))
          "\n      ")))
    (string-append
     ";;; -*- Mode: Lisp; Syntax: Common-Lisp -*-\n"
     ";;; Имя: " имя-комб "\n"
     ";;; Описание: Ветвление — выбор потока по содержимому задачи\n"
     "\n"
     "(defpackage :поток-" имя-комб " (:use :cl))\n"
     "(in-package :поток-" имя-комб ")\n"
     "\n"
     ";;; --- загрузка подпотоков ---\n"
     загрузки "\n"
     "\n"
     ";;; --- точка входа ---\n"
     "(defun выполнить (задача)\n"
     "  \"Ветвление: выбор потока по ключевым словам в задаче.\"\n"
     "  (cond\n"
     "      " ветви "\n"
     "      (t (format nil \"Ни одно условие не подошло для: ~a\" задача))))\n")))

;; --- создание комбинированного потока ---

(define (создать-цепочку каталог имена)
  (let* ((пары (собрать-пути-потоков каталог имена))
         (имя-комб (string-append "цепочка-" (string-join имена "-")))
         (код (шаблон-цепочки имя-комб пары))
         (описание (string-append "Цепочка: " (string-join имена " → "))))
    (let ((путь (записать-поток каталог имя-комб код)))
      (записать-мета каталог имя-комб описание)
      (list имя-комб путь описание))))

(define (создать-параллель каталог имена)
  (let* ((пары (собрать-пути-потоков каталог имена))
         (имя-комб (string-append "параллель-" (string-join имена "-")))
         (код (шаблон-параллели имя-комб пары))
         (описание (string-append "Параллель: " (string-join имена " | "))))
    (let ((путь (записать-поток каталог имя-комб код)))
      (записать-мета каталог имя-комб описание)
      (list имя-комб путь описание))))

(define (создать-ветвление каталог пары-условие-имя)
  (let* ((имена (map second пары-условие-имя))
         (пути (собрать-пути-потоков каталог имена))
         (тройки (for/list ([пу (in-list пары-условие-имя)]
                            [пп (in-list пути)])
                   (list (first пу) (second пу) (cdr пп))))
         (имя-комб (string-append "ветвление-" (string-join имена "-")))
         (код (шаблон-ветвления имя-комб тройки))
         (описание (string-append "Ветвление: "
                                  (string-join
                                   (for/list ([п (in-list пары-условие-имя)])
                                     (format "~a→~a" (first п) (second п)))
                                   ", "))))
    (let ((путь (записать-поток каталог имя-комб код)))
      (записать-мета каталог имя-комб описание)
      (list имя-комб путь описание))))

;; --- комбинирование через Claude Code ---

(define (комбинировать-через-клод душа описание каталог)
  (let* ((потоки (список-потоков каталог))
         (список-стр (if (null? потоки)
                         "Потоков нет."
                         (string-join
                          (for/list ([п (in-list потоки)])
                            (format "- ~a: ~a" (first п) (second п)))
                          "\n")))
         (задание
          (string-append
           "Ты генератор комбинированных вычислительных потоков на Common Lisp.\n"
           "Девиз: " (or (получить-поле душа 'девиз) "") "\n\n"
           "Существующие потоки:\n" список-стр "\n\n"
           "Задача комбинирования: " описание "\n\n"
           "Требования:\n"
           "- Создай пакет :поток-<имя>\n"
           "- Функция (defun выполнить (задача) ...) — точка входа\n"
           "- Загрузи нужные подпотоки через (load путь :verbose nil :print nil)\n"
           "- Вызывай подпотоки через (funcall (symbol-function (find-symbol \"ВЫПОЛНИТЬ\" (find-package ...))) задача)\n"
           "- Придумай оригинальный способ комбинирования\n"
           "- Рекурсия вместо loop, функции до 15 строк\n"
           "- Русские имена, в духе SICP\n"
           "- Верни ТОЛЬКО код Common Lisp, без пояснений\n"))
         (ответ (спросить-клод задание))
         (код (извлечь-код ответ))
         (имя (имя-пакета код))
         (путь-потока (записать-поток каталог имя код)))
    (записать-мета каталог имя описание)
    (let-values ([(успех? вывод) (проверить-поток путь-потока)])
      (list успех? имя путь-потока описание вывод))))
