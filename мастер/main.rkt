#lang racket/base

;;; Мастер — бот-оркестратор
;;; Минимальный Telegram-бот: подключение к API, эхо-ответ

(require json
         net/url
         racket/format
         racket/list
         racket/match
         racket/port
         racket/runtime-path
         racket/string
         "dusha.rkt"
         "potoki.rkt"
         "kombinirovanie.rkt")

(provide разобрать-обновления
         извлечь-сообщения
         сформировать-ответ
         послать-сообщение
         получить-обновления
         запустить-опрос
         загрузить-душу
         текущая-душа
         каталог-потоков
         обработать-породить
         обработать-потоки
         обработать-запустить
         обработать-остановить
         обработать-переключить
         обработать-использовать
         обработать-состояние
         обработать-цепочку
         обработать-параллель
         обработать-ветвление
         обработать-комбинировать)

;; --- настройки ---

(define (ключ-бота)
  (or (getenv "MASTER_BOT_TOKEN")
      (error 'ключ-бота "Не задана переменная MASTER_BOT_TOKEN")))

(define (адрес-api метод)
  (string-append "https://api.telegram.org/bot" (ключ-бота) "/" метод))

(define-runtime-path корень ".")
(define (путь-души) (build-path корень "душа.scm"))
(define (каталог-истории) (build-path корень "история"))
(define каталог-потоков (make-parameter (build-path корень "потоки")))

;; --- душа ---

(define текущая-душа (make-parameter #f))

(define (загрузить-душу)
  (текущая-душа (прочитать-душу (путь-души))))

;; --- разбор обновлений ---

(define (разобрать-обновления текст)
  (with-handlers ([exn:fail? (lambda (_) '())])
    (let ((данные (string->jsexpr текст)))
      (if (and (hash? данные)
               (hash-ref данные 'ok #f))
          (hash-ref данные 'result '())
          '()))))

(define (извлечь-сообщения обновления)
  (for/list ([обн (in-list обновления)]
             #:when (and (hash? обн)
                         (hash-has-key? обн 'message)))
    (let* ((сообщ (hash-ref обн 'message))
           (ид-обн (hash-ref обн 'update_id 0))
           (чат (hash-ref сообщ 'chat (hash)))
           (ид-чата (hash-ref чат 'id 0))
           (текст (hash-ref сообщ 'text "")))
      (list ид-обн ид-чата текст))))

;; --- формирование ответа ---

(define (сформировать-ответ текст)
  (cond
    [(string=? текст "/время") (формат-время)]
    [(string=? текст "/состояние") (обработать-состояние)]
    [(string=? текст "/душа") (обработать-душу)]
    [(string=? текст "/память") (обработать-память)]
    [(string=? текст "/потоки") (обработать-потоки)]
    [(string=? текст "/остановить") (обработать-остановить)]
    [(строка-начинается? текст "/породить ")
     (обработать-породить (substring текст 10))]
    [(строка-начинается? текст "/запустить ")
     (обработать-запустить (string-trim (substring текст 11)))]
    [(строка-начинается? текст "/переключить ")
     (обработать-переключить (string-trim (substring текст 13)))]
    [(строка-начинается? текст "/использовать ")
     (обработать-использовать (string-trim (substring текст 14)))]
    [(строка-начинается? текст "/цепочка ")
     (обработать-цепочку (string-trim (substring текст 9)))]
    [(строка-начинается? текст "/параллель ")
     (обработать-параллель (string-trim (substring текст 11)))]
    [(строка-начинается? текст "/ветвление ")
     (обработать-ветвление (string-trim (substring текст 11)))]
    [(строка-начинается? текст "/комбинировать ")
     (обработать-комбинировать (string-trim (substring текст 15)))]
    [else (string-append "Эхо: " текст)]))

(define (строка-начинается? строка префикс)
  (and (>= (string-length строка) (string-length префикс))
       (string=? (substring строка 0 (string-length префикс)) префикс)))

(define (обработать-породить описание)
  (let ((д (текущая-душа)))
    (if (not д)
        "Душа не загружена. Не могу породить поток."
        (with-handlers ([exn:fail?
                         (lambda (e)
                           (format "Ошибка порождения: ~a" (exn-message e)))])
          (let ((результат (породить-поток д описание (каталог-потоков))))
            (let ((успех? (first результат))
                  (имя (second результат))
                  (путь (third результат)))
              (if успех?
                  (format "Поток ~a порождён и проверен.\nФайл: ~a" имя путь)
                  (format "Поток ~a порождён, но проверка не пройдена.\nФайл: ~a"
                          имя путь))))))))

(define (обработать-душу)
  (let ((д (текущая-душа)))
    (if д (показать-душу д) "Душа не загружена.")))

(define (обработать-память)
  (let ((д (текущая-душа)))
    (if д (показать-память д) "Душа не загружена.")))

;; --- управление потоками ---

(define (обработать-состояние)
  (let ((актив (прочитать-активный (каталог-потоков))))
    (if актив
        (format "Активный поток: ~a\nПакет: ~a" (first актив) (third актив))
        "Нет активного потока.")))

(define (обработать-потоки)
  (let ((потоки (список-потоков (каталог-потоков))))
    (if (null? потоки)
        "Потоков нет."
        (let ((актив (прочитать-активный (каталог-потоков))))
          (string-join
           (for/list ([п (in-list потоки)])
             (let* ((имя (first п))
                    (описание (second п))
                    (активен? (and актив (string=? имя (first актив)))))
               (format "~a~a — ~a"
                       (if активен? "▶ " "  ")
                       имя описание)))
           "\n")))))

(define (обработать-запустить имя)
  (let ((поток (найти-поток (каталог-потоков) имя)))
    (if (not поток)
        (format "Поток ~a не найден." имя)
        (let* ((актив (прочитать-активный (каталог-потоков)))
               (мета (third поток))
               (пакет (if мета
                          (string-append "поток-" (or (поле-меты мета 'имя) имя))
                          (string-append "поток-" имя))))
          (if (and актив (string=? (first актив) имя))
              (format "Поток ~a уже запущен." имя)
              (begin
                (записать-активный (каталог-потоков) имя пакет)
                (format "Поток ~a запущен." имя)))))))

(define (обработать-остановить)
  (let ((актив (прочитать-активный (каталог-потоков))))
    (if (not актив)
        "Нет активного потока."
        (begin
          (удалить-активный (каталог-потоков))
          (format "Поток ~a остановлен." (first актив))))))

(define (обработать-переключить имя)
  (let ((актив (прочитать-активный (каталог-потоков))))
    (when актив (удалить-активный (каталог-потоков)))
    (обработать-запустить имя)))

(define (обработать-использовать имя)
  (let ((поток (найти-поток (каталог-потоков) имя)))
    (if (not поток)
        (format "Поток ~a не найден." имя)
        (let* ((мета (third поток))
               (описание (if мета
                             (or (поле-меты мета 'описание) "без описания")
                             "без описания")))
          (обработать-запустить имя)
          (format "Поток ~a загружен для использования.\nОписание: ~a" имя описание)))))

;; --- комбинирование потоков ---

(define (обработать-цепочку аргументы)
  (let ((имена (string-split аргументы)))
    (if (< (length имена) 2)
        "Укажите минимум два потока: /цепочка имя1 имя2 ..."
        (with-handlers ([exn:fail?
                         (lambda (e)
                           (format "Ошибка: ~a" (exn-message e)))])
          (let ((результат (создать-цепочку (каталог-потоков) имена)))
            (format "Цепочка ~a создана.\n~a" (first результат) (third результат)))))))

(define (обработать-параллель аргументы)
  (let ((имена (string-split аргументы)))
    (if (< (length имена) 2)
        "Укажите минимум два потока: /параллель имя1 имя2 ..."
        (with-handlers ([exn:fail?
                         (lambda (e)
                           (format "Ошибка: ~a" (exn-message e)))])
          (let ((результат (создать-параллель (каталог-потоков) имена)))
            (format "Параллель ~a создана.\n~a" (first результат) (third результат)))))))

(define (обработать-ветвление аргументы)
  (let ((части (string-split аргументы)))
    (let ((пары (разобрать-пары-ветвления части)))
      (if (or (not пары) (< (length пары) 2))
          "Формат: /ветвление ключ1:имя1 ключ2:имя2 ..."
          (with-handlers ([exn:fail?
                           (lambda (e)
                             (format "Ошибка: ~a" (exn-message e)))])
            (let ((результат (создать-ветвление (каталог-потоков) пары)))
              (format "Ветвление ~a создано.\n~a" (first результат) (third результат))))))))

(define (разобрать-пары-ветвления части)
  (with-handlers ([exn:fail? (lambda (_) #f)])
    (for/list ([ч (in-list части)])
      (let ((поз (string-index ч #\:)))
        (if поз
            (list (substring ч 0 поз) (substring ч (+ поз 1)))
            (error "нет разделителя"))))))

(define (string-index строка символ)
  (let ищи ((и 0))
    (cond
      [(>= и (string-length строка)) #f]
      [(char=? (string-ref строка и) символ) и]
      [else (ищи (+ и 1))])))

(define (обработать-комбинировать описание)
  (let ((д (текущая-душа)))
    (if (not д)
        "Душа не загружена. Не могу комбинировать."
        (with-handlers ([exn:fail?
                         (lambda (e)
                           (format "Ошибка комбинирования: ~a" (exn-message e)))])
          (let ((результат (комбинировать-через-клод д описание (каталог-потоков))))
            (let ((успех? (first результат))
                  (имя (second результат)))
              (if успех?
                  (format "Комбинация ~a создана и проверена." имя)
                  (format "Комбинация ~a создана, но проверка не пройдена." имя))))))))

(define (формат-время)
  (let ((сейчас (seconds->date (current-seconds))))
    (format "~a-~a-~a ~a:~a:~a"
            (date-year сейчас)
            (~два (date-month сейчас))
            (~два (date-day сейчас))
            (~два (date-hour сейчас))
            (~два (date-minute сейчас))
            (~два (date-second сейчас)))))

(define (~два ч)
  (~a ч #:min-width 2 #:pad-string "0" #:align 'right))

;; --- отправка ---

(define (послать-сообщение ид-чата текст)
  (let* ((тело (jsexpr->string
                (hash 'chat_id ид-чата
                      'text текст)))
         (адрес (string->url (адрес-api "sendMessage")))
         (заголовки '("Content-Type: application/json"))
         (порт (post-pure-port адрес
                               (string->bytes/utf-8 тело)
                               заголовки)))
    (begin0
      (port->string порт)
      (close-input-port порт))))

;; --- получение обновлений ---

(define (получить-обновления сдвиг)
  (let* ((адрес (string->url
                 (string-append (адрес-api "getUpdates")
                                "?timeout=30"
                                "&offset="
                                (number->string сдвиг))))
         (порт (get-pure-port адрес)))
    (begin0
      (port->string порт)
      (close-input-port порт))))

;; --- цикл опроса ---

(define (запустить-опрос)
  (загрузить-душу)
  (displayln "Мастер запущен. Ожидаю сообщения...")
  (let цикл ((сдвиг 0))
    (with-handlers ([exn:fail:network?
                     (lambda (e)
                       (displayln (format "Ошибка сети: ~a" (exn-message e)))
                       (sleep 5)
                       (цикл сдвиг))])
      (let* ((ответ (получить-обновления сдвиг))
             (обновления (разобрать-обновления ответ))
             (сообщения (извлечь-сообщения обновления)))
        (let обр ((ост сообщения) (макс-сдвиг сдвиг))
          (if (null? ост)
              (цикл макс-сдвиг)
              (let* ((сообщ (car ост))
                     (ид-обн (first сообщ))
                     (ид-чата (second сообщ))
                     (текст (third сообщ))
                     (ответ-текст (сформировать-ответ текст)))
                (displayln (format "< ~a" текст))
                (displayln (format "> ~a" ответ-текст))
                (записать-историю (каталог-истории) ид-чата текст ответ-текст)
                (послать-сообщение ид-чата ответ-текст)
                (обр (cdr ост) (max макс-сдвиг (+ ид-обн 1))))))))))

;; --- точка входа ---

(module+ main
  (запустить-опрос))
