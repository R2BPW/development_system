#lang racket/base

;;; Тесты для модуля души — чтение, запись, память, история

(require rackunit
         racket/file
         racket/format
         racket/list
         racket/path
         racket/string
         "dusha.rkt")

;; --- вспомогательные ---

(define тестовый-каталог (make-temporary-file "душа-тест-~a" 'directory))

(define тестовая-душа
  '(душа
    (указание  "Тестовый помощник")
    (модель    "test-model")
    (теплота   0.5)
    (память    ((предпочитает . "рекурсию")))
    (девиз     "тест")))

(define пустая-душа
  '(душа
    (указание  "Пусто")
    (модель    "m")
    (теплота   0)
    (память    ())
    (девиз     "д")))

;; --- тесты чтения/записи ---

(test-case "записать и прочитать душу"
  (let ((файл (build-path тестовый-каталог "душа.scm")))
    (записать-душу файл тестовая-душа)
    (let ((результат (прочитать-душу файл)))
      (check-equal? результат тестовая-душа))))

(test-case "прочитать душу: файл не существует"
  (check-false (прочитать-душу "/несуществующий/путь/душа.scm")))

;; --- тесты доступа к полям ---

(test-case "получить-поле: указание"
  (check-equal? (получить-поле тестовая-душа 'указание) "Тестовый помощник"))

(test-case "получить-поле: модель"
  (check-equal? (получить-поле тестовая-душа 'модель) "test-model"))

(test-case "получить-поле: теплота"
  (check-equal? (получить-поле тестовая-душа 'теплота) 0.5))

(test-case "получить-поле: память"
  (check-equal? (получить-поле тестовая-душа 'память)
                '((предпочитает . "рекурсию"))))

(test-case "получить-поле: несуществующее"
  (check-false (получить-поле тестовая-душа 'нет-такого)))

(test-case "получить-поле: не-душа"
  (check-false (получить-поле "не душа" 'модель)))

;; --- тесты отображения ---

(test-case "показать-душу: нормальная"
  (let ((текст (показать-душу тестовая-душа)))
    (check-true (string-contains? текст "указание"))
    (check-true (string-contains? текст "Тестовый помощник"))
    (check-true (string-contains? текст "модель"))
    (check-true (string-contains? текст "девиз"))))

(test-case "показать-душу: не-душа"
  (check-equal? (показать-душу #f) "Душа не найдена."))

(test-case "показать-память: с фактами"
  (let ((текст (показать-память тестовая-душа)))
    (check-true (string-contains? текст "предпочитает"))
    (check-true (string-contains? текст "рекурсию"))))

(test-case "показать-память: пустая"
  (check-equal? (показать-память пустая-душа) "Память пуста."))

;; --- тесты добавления памяти ---

(test-case "добавить-память: в пустую"
  (let ((новая (добавить-память пустая-душа '(знает . "лисп"))))
    (check-equal? (получить-поле новая 'память) '((знает . "лисп")))))

(test-case "добавить-память: к существующей"
  (let ((новая (добавить-память тестовая-душа '(знает . "лисп"))))
    (check-equal? (получить-поле новая 'память)
                  '((предпочитает . "рекурсию") (знает . "лисп")))))

;; --- тесты истории ---

(test-case "записать и прочитать историю"
  (let ((каталог (build-path тестовый-каталог "история")))
    (записать-историю каталог 42 "привет" "Эхо: привет")
    (let ((текст (прочитать-историю каталог (дата-сегодня))))
      (check-true (string? текст))
      (check-true (string-contains? текст "привет"))
      (check-true (string-contains? текст "Эхо: привет"))
      (check-true (string-contains? текст "чат:42")))))

(test-case "прочитать историю: нет файла"
  (check-false (прочитать-историю тестовый-каталог "1900-01-01")))

(test-case "записать историю: несколько записей"
  (let ((каталог (build-path тестовый-каталог "история2")))
    (записать-историю каталог 1 "а" "б")
    (записать-историю каталог 2 "в" "г")
    (let ((текст (прочитать-историю каталог (дата-сегодня))))
      (check-true (string-contains? текст "чат:1"))
      (check-true (string-contains? текст "чат:2")))))

(test-case "дата-сегодня: формат ГГГГ-ММ-ДД"
  (let ((д (дата-сегодня)))
    (check-true (regexp-match? #px"^\\d{4}-\\d{2}-\\d{2}$" д))))

;; --- очистка ---
(delete-directory/files тестовый-каталог)

(displayln "Все тесты души пройдены.")
