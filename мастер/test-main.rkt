#lang racket/base

;;; Тесты для Мастера — разбор обновлений, формирование ответов

(require rackunit
         json
         racket/file
         racket/list
         racket/path
         racket/string
         "main.rkt"
         "dusha.rkt"
         "potoki.rkt"
         "kombinirovanie.rkt")

;; --- тесты разбора обновлений ---

(test-case "разобрать-обновления: корректный ответ"
  (let* ((данные (jsexpr->string
                  (hash 'ok #t
                        'result (list
                                 (hash 'update_id 1
                                       'message
                                       (hash 'chat (hash 'id 42)
                                             'text "привет"))))))
         (результат (разобрать-обновления данные)))
    (check-equal? (length результат) 1)
    (check-true (hash? (car результат)))))

(test-case "разобрать-обновления: некорректный JSON"
  (check-equal? (разобрать-обновления "не json") '()))

(test-case "разобрать-обновления: ok=false"
  (let ((данные (jsexpr->string (hash 'ok #f 'result '()))))
    (check-equal? (разобрать-обновления данные) '())))

(test-case "разобрать-обновления: пустой результат"
  (let ((данные (jsexpr->string (hash 'ok #t 'result '()))))
    (check-equal? (разобрать-обновления данные) '())))

;; --- тесты извлечения сообщений ---

(test-case "извлечь-сообщения: одно сообщение"
  (let* ((обновления (list (hash 'update_id 1
                                 'message (hash 'chat (hash 'id 42)
                                                'text "тест"))))
         (сообщения (извлечь-сообщения обновления)))
    (check-equal? (length сообщения) 1)
    (check-equal? (first (car сообщения)) 1)
    (check-equal? (second (car сообщения)) 42)
    (check-equal? (third (car сообщения)) "тест")))

(test-case "извлечь-сообщения: обновление без message"
  (let ((обновления (list (hash 'update_id 1))))
    (check-equal? (извлечь-сообщения обновления) '())))

(test-case "извлечь-сообщения: несколько сообщений"
  (let* ((обновления (list (hash 'update_id 1
                                 'message (hash 'chat (hash 'id 10)
                                                'text "а"))
                           (hash 'update_id 2
                                 'message (hash 'chat (hash 'id 20)
                                                'text "б"))))
         (сообщения (извлечь-сообщения обновления)))
    (check-equal? (length сообщения) 2)
    (check-equal? (third (first сообщения)) "а")
    (check-equal? (third (second сообщения)) "б")))

;; --- тесты формирования ответа ---

(test-case "сформировать-ответ: эхо"
  (check-equal? (сформировать-ответ "привет") "Эхо: привет"))

(test-case "сформировать-ответ: /время"
  (let ((ответ (сформировать-ответ "/время")))
    (check-true (string? ответ))
    (check-true (> (string-length ответ) 10))))

(test-case "сформировать-ответ: /состояние без потока"
  (let ((кат (make-temporary-file "потоки-~a" 'directory)))
    (parameterize ([каталог-потоков кат])
      (check-equal? (сформировать-ответ "/состояние") "Нет активного потока."))
    (delete-directory/files кат)))

;; --- тесты команд души ---

(test-case "сформировать-ответ: /душа без загрузки"
  (parameterize ([текущая-душа #f])
    (check-equal? (сформировать-ответ "/душа") "Душа не загружена.")))

(test-case "сформировать-ответ: /душа с загруженной душой"
  (parameterize ([текущая-душа
                  '(душа
                    (указание "Тест")
                    (модель "m")
                    (теплота 0)
                    (память ())
                    (девиз "д"))])
    (let ((ответ (сформировать-ответ "/душа")))
      (check-true (string-contains? ответ "указание"))
      (check-true (string-contains? ответ "Тест")))))

(test-case "сформировать-ответ: /память без загрузки"
  (parameterize ([текущая-душа #f])
    (check-equal? (сформировать-ответ "/память") "Душа не загружена.")))

(test-case "сформировать-ответ: /память пустая"
  (parameterize ([текущая-душа
                  '(душа (память ()))])
    (check-equal? (сформировать-ответ "/память") "Память пуста.")))

(test-case "сформировать-ответ: /память с фактами"
  (parameterize ([текущая-душа
                  '(душа (память ((знает . "лисп"))))])
    (let ((ответ (сформировать-ответ "/память")))
      (check-true (string-contains? ответ "знает"))
      (check-true (string-contains? ответ "лисп")))))

;; --- тесты команды /породить ---

(test-case "сформировать-ответ: /породить без души"
  (parameterize ([текущая-душа #f])
    (check-equal? (сформировать-ответ "/породить тест")
                  "Душа не загружена. Не могу породить поток.")))

;; --- тесты управления потоками ---

(define тест-код-поток
  (string-append
   "(defpackage :поток-тест (:use :cl))\n"
   "(in-package :поток-тест)\n"
   "(defun выполнить (задача) задача)\n"))

(test-case "сформировать-ответ: /потоки пустой"
  (let ((кат (make-temporary-file "потоки-~a" 'directory)))
    (parameterize ([каталог-потоков кат])
      (check-equal? (сформировать-ответ "/потоки") "Потоков нет."))
    (delete-directory/files кат)))

(test-case "сформировать-ответ: /потоки с потоком"
  (let ((кат (make-temporary-file "потоки-~a" 'directory)))
    (записать-поток кат "эхо" тест-код-поток)
    (записать-мета кат "эхо" "Тестовый эхо")
    (parameterize ([каталог-потоков кат])
      (let ((ответ (сформировать-ответ "/потоки")))
        (check-true (string-contains? ответ "эхо"))
        (check-true (string-contains? ответ "Тестовый эхо"))))
    (delete-directory/files кат)))

(test-case "сформировать-ответ: /запустить"
  (let ((кат (make-temporary-file "потоки-~a" 'directory)))
    (записать-поток кат "эхо" тест-код-поток)
    (записать-мета кат "эхо" "Тестовый эхо")
    (parameterize ([каталог-потоков кат])
      (let ((ответ (сформировать-ответ "/запустить эхо")))
        (check-true (string-contains? ответ "запущен")))
      (check-true (list? (прочитать-активный кат))))
    (delete-directory/files кат)))

(test-case "сформировать-ответ: /запустить несуществующий"
  (let ((кат (make-temporary-file "потоки-~a" 'directory)))
    (parameterize ([каталог-потоков кат])
      (let ((ответ (сформировать-ответ "/запустить нет")))
        (check-true (string-contains? ответ "не найден"))))
    (delete-directory/files кат)))

(test-case "сформировать-ответ: /остановить"
  (let ((кат (make-temporary-file "потоки-~a" 'directory)))
    (записать-поток кат "эхо" тест-код-поток)
    (записать-мета кат "эхо" "Тестовый")
    (parameterize ([каталог-потоков кат])
      (сформировать-ответ "/запустить эхо")
      (let ((ответ (сформировать-ответ "/остановить")))
        (check-true (string-contains? ответ "остановлен")))
      (check-false (прочитать-активный кат)))
    (delete-directory/files кат)))

(test-case "сформировать-ответ: /остановить без активного"
  (let ((кат (make-temporary-file "потоки-~a" 'directory)))
    (parameterize ([каталог-потоков кат])
      (check-equal? (сформировать-ответ "/остановить") "Нет активного потока."))
    (delete-directory/files кат)))

(test-case "сформировать-ответ: /переключить"
  (let ((кат (make-temporary-file "потоки-~a" 'directory)))
    (записать-поток кат "альфа" тест-код-поток)
    (записать-мета кат "альфа" "Первый")
    (записать-поток кат "бета" тест-код-поток)
    (записать-мета кат "бета" "Второй")
    (parameterize ([каталог-потоков кат])
      (сформировать-ответ "/запустить альфа")
      (let ((ответ (сформировать-ответ "/переключить бета")))
        (check-true (string-contains? ответ "запущен")))
      (let ((актив (прочитать-активный кат)))
        (check-equal? (first актив) "бета")))
    (delete-directory/files кат)))

(test-case "сформировать-ответ: /использовать"
  (let ((кат (make-temporary-file "потоки-~a" 'directory)))
    (записать-поток кат "эхо" тест-код-поток)
    (записать-мета кат "эхо" "Тестовый эхо")
    (parameterize ([каталог-потоков кат])
      (let ((ответ (сформировать-ответ "/использовать эхо")))
        (check-true (string-contains? ответ "загружен"))
        (check-true (string-contains? ответ "Тестовый эхо"))))
    (delete-directory/files кат)))

(test-case "сформировать-ответ: /состояние с активным потоком"
  (let ((кат (make-temporary-file "потоки-~a" 'directory)))
    (записать-поток кат "эхо" тест-код-поток)
    (записать-мета кат "эхо" "Тестовый")
    (parameterize ([каталог-потоков кат])
      (сформировать-ответ "/запустить эхо")
      (let ((ответ (сформировать-ответ "/состояние")))
        (check-true (string-contains? ответ "эхо"))))
    (delete-directory/files кат)))

(test-case "сформировать-ответ: /состояние без потока"
  (let ((кат (make-temporary-file "потоки-~a" 'directory)))
    (parameterize ([каталог-потоков кат])
      (check-equal? (сформировать-ответ "/состояние") "Нет активного потока."))
    (delete-directory/files кат)))

;; --- тесты комбинирования ---

(define тест-код-обёртка
  (string-append
   "(defpackage :поток-обёртка (:use :cl))\n"
   "(in-package :поток-обёртка)\n"
   "(defun выполнить (задача)\n"
   "  (format nil \"[~a]\" задача))\n"))

(test-case "сформировать-ответ: /цепочка без аргументов"
  (check-true (string-contains?
               (сформировать-ответ "/цепочка один")
               "минимум два")))

(test-case "сформировать-ответ: /цепочка создаёт поток"
  (let ((кат (make-temporary-file "потоки-~a" 'directory)))
    (записать-поток кат "эхо" тест-код-поток)
    (записать-мета кат "эхо" "Эхо")
    (записать-поток кат "обёртка" тест-код-обёртка)
    (записать-мета кат "обёртка" "Обёртка")
    (parameterize ([каталог-потоков кат])
      (let ((ответ (сформировать-ответ "/цепочка эхо обёртка")))
        (check-true (string-contains? ответ "создана"))
        (check-true (string-contains? ответ "Цепочка"))))
    (delete-directory/files кат)))

(test-case "сформировать-ответ: /параллель создаёт поток"
  (let ((кат (make-temporary-file "потоки-~a" 'directory)))
    (записать-поток кат "эхо" тест-код-поток)
    (записать-мета кат "эхо" "Эхо")
    (записать-поток кат "обёртка" тест-код-обёртка)
    (записать-мета кат "обёртка" "Обёртка")
    (parameterize ([каталог-потоков кат])
      (let ((ответ (сформировать-ответ "/параллель эхо обёртка")))
        (check-true (string-contains? ответ "создана"))
        (check-true (string-contains? ответ "Параллель"))))
    (delete-directory/files кат)))

(test-case "сформировать-ответ: /ветвление создаёт поток"
  (let ((кат (make-temporary-file "потоки-~a" 'directory)))
    (записать-поток кат "эхо" тест-код-поток)
    (записать-мета кат "эхо" "Эхо")
    (записать-поток кат "обёртка" тест-код-обёртка)
    (записать-мета кат "обёртка" "Обёртка")
    (parameterize ([каталог-потоков кат])
      (let ((ответ (сформировать-ответ "/ветвление привет:эхо оберни:обёртка")))
        (check-true (string-contains? ответ "создано"))
        (check-true (string-contains? ответ "Ветвление"))))
    (delete-directory/files кат)))

(test-case "сформировать-ответ: /ветвление без формата"
  (check-true (string-contains?
               (сформировать-ответ "/ветвление один")
               "Формат")))

(test-case "сформировать-ответ: /комбинировать без души"
  (parameterize ([текущая-душа #f])
    (check-equal? (сформировать-ответ "/комбинировать тест")
                  "Душа не загружена. Не могу комбинировать.")))

(test-case "сформировать-ответ: /цепочка с несуществующим потоком"
  (let ((кат (make-temporary-file "потоки-~a" 'directory)))
    (записать-поток кат "эхо" тест-код-поток)
    (записать-мета кат "эхо" "Эхо")
    (parameterize ([каталог-потоков кат])
      (let ((ответ (сформировать-ответ "/цепочка эхо нет-такого")))
        (check-true (string-contains? ответ "Ошибка"))))
    (delete-directory/files кат)))

(displayln "Все тесты Мастера пройдены.")
