;; потоки-сессии.scm
;; Реестр типов потоков, выявленных в сессии MC218-AI
;; Каждый поток: (имя тип вход выход)

(реестр
  ;; ── Потоки-артефакты: создают файл ────────────────
  (документация
    :тип артефакт
    :вход "контекст проекта + указание формата"
    :выход "LaTeX → PDF"
    :примеры ("pda-ai-project.pdf" "mc218-ai-hardware.pdf")
    :уточнение "повторные вызовы мутируют тот же файл")

  (публикация
    :тип артефакт
    :вход "набор файлов + credentials"
    :выход "git push (внешний эффект)"
    :примеры ("github.com/R2BPW/mc218-ai"))

  (план
    :тип порождатель
    :вход "анализ проблем + формат ralphex"
    :выход ".md файл с задачами для автономного исполнения"
    :примеры ("product-readiness.md" "flipper-ai-modem.md" "safety-nets.md")
    :свойство "каждый план — порождатель потоков для ralphex")

  ;; ── Потоки-исследования: накапливают решение ──────
  (исследование
    :тип исследование
    :вход "вопрос или URL"
    :выход "решение (текст или ссылка)"
    :примеры ("поиск компонентов" "анализ кабеля" "flipper GPIO")
    :свойство "серия подзапросов сужает пространство до одного решения")

  (архитектура
    :тип исследование
    :вход "серия уточняющих вопросов"
    :выход "схема подключения + распиновка + выбор компонентов"
    :примеры ("flipper как модем" "backpack vs devboard" "UART1/UART2")
    :свойство "каждый подзапрос переключает фокус но не сбрасывает контекст")

  ;; ── Потоки-верификаторы: проверяют инвариант ──────
  (аудит
    :тип верификатор
    :вход "репозиторий или diff"
    :выход "t | список нарушений"
    :примеры ("credentials в коде" "ревью после обновления" "gap-анализ покрытия рисков"))

  ;; ── Потоки-анализаторы: порождают входы для других ─
  (анализ-рисков
    :тип анализ → порождатель
    :вход "архитектура целиком"
    :выход "список точек отказа → план страховок"
    :свойство "цепочка: анализ → текст → план → ralphex → код"))
