;;; -*- Mode: Lisp; Coding: utf-8 -*-
;;; tracer.lisp — трассировка вычислений как S-выражения

(defpackage :трас
  (:use :cl)
  (:export :начать-след
           :записать-шаг
           :завершить-след
           :*путь-журнала*
           :*имя-потока*
           :*задача*))

(in-package :трас)

;;; --- глобальное состояние трассировки ---

(defvar *путь-журнала* nil "Путь к файлу журнала.")
(defvar *имя-потока*   ""  "Имя активного потока.")
(defvar *задача*       ""  "Текущая задача.")
(defvar *шаги*         nil "Накопленные шаги.")
(defvar *начало*       0   "Время начала в мс.")

;;; --- вспомогательные ---

(defun мс-сейчас ()
  (floor (* 1000
            (/ (get-internal-real-time)
               internal-time-units-per-second))))

(defun сейчас-iso ()
  (multiple-value-bind (с мин ч д мес г)
      (decode-universal-time (get-universal-time))
    (format nil "~4d-~2,'0d-~2,'0dT~2,'0d:~2,'0d:~2,'0d"
            г мес д ч мин с)))

;;; --- API трассировки ---

(defun начать-след (имя задача)
  "Инициализирует новую трассировку."
  (setf *имя-потока* имя
        *задача*     задача
        *шаги*       nil
        *начало*     (мс-сейчас)))

(defun записать-шаг (номер вход ответ &key (качество :неизвестно))
  "Добавляет шаг вычисления в журнал."
  (let ((мс (- (мс-сейчас) *начало*)))
    (push `(шаг
              (номер    ,номер)
              (вход     ,вход)
              (ответ    ,ответ)
              (мс       ,мс)
              (качество ,качество))
          *шаги*)))

(defun завершить-след (итог)
  "Записывает финальный след в файл."
  (when *путь-журнала*
    (let* ((мс-всего  (- (мс-сейчас) *начало*))
           (запись
            `(след
               (поток      ,*имя-потока*)
               (время      ,(сейчас-iso))
               (задача     ,*задача*)
               (шаги       ,@(reverse *шаги*))
               (итог       ,итог)
               (мс-всего   ,мс-всего)
               (итераций   ,(length *шаги*)))))
      (with-open-file
          (ф *путь-журнала*
             :direction :output
             :if-exists :append
             :if-does-not-exist :create
             :external-format :utf-8)
        (write запись ф :readably t)
        (terpri ф)))))
