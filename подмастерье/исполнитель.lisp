;;; -*- Mode: Lisp; Syntax: Common-Lisp -*-
;;; Подмастерье — исполнитель вычислительных потоков
;;; Загружает поток из файла, вызывает точку входа, обрабатывает условия
;;; Поддерживает сохранение/восстановление образов SBCL

(defpackage :исполнитель
  (:use :cl)
  (:export :загрузить-поток
           :выполнить-задачу
           :найти-точку-входа
           :запуск
           :выполнить-с-повтором
           :сохранить-образ
           :путь-образа
           :текущий-поток-функция
           :текущий-поток-пакет))

(in-package :исполнитель)

;;; --- состояние ---

(defvar *текущий-поток-пакет* nil
  "Имя пакета текущего загруженного потока.")

(defvar *текущий-поток-функция* nil
  "Функция точки входа текущего потока.")

(defun текущий-поток-пакет () *текущий-поток-пакет*)
(defun текущий-поток-функция () *текущий-поток-функция*)

;;; --- загрузка потока ---

(defun загрузить-поток (путь)
  "Загружает файл потока (.lisp) в текущий образ.
   Возвращает T при успехе, сигнализирует условие при ошибке."
  (restart-case
      (progn
        (unless (probe-file путь)
          (error "Файл потока не найден: ~a" путь))
        (load путь :verbose nil :print nil)
        t)
    (пропустить ()
      :report "Пропустить загрузку потока"
      nil)))

;;; --- поиск точки входа ---

(defun найти-точку-входа (имя-пакета)
  "Ищет функцию ВЫПОЛНИТЬ в указанном пакете.
   Возвращает функцию или NIL."
  (let ((пакет (find-package (string-upcase имя-пакета))))
    (when пакет
      (let ((символ (find-symbol "ВЫПОЛНИТЬ" пакет)))
        (when (and символ (fboundp символ))
          (symbol-function символ))))))

;;; --- выполнение задачи с обработкой условий ---

(defun выполнить-задачу (поток-функция задача)
  "Вызывает функцию потока с задачей, оборачивая в обработку условий.
   Возвращает результат или сообщение об ошибке."
  (restart-case
      (handler-case
          (funcall поток-функция задача)
        (error (у)
          (format nil "Ошибка выполнения: ~a" у)))
    (повторить ()
      :report "Повторить выполнение задачи"
      (выполнить-задачу поток-функция задача))
    (подменить (значение)
      :report "Использовать запасное значение"
      :interactive (lambda ()
                     (format t "Введите запасное значение: ")
                     (list (read)))
      значение)))

;;; --- выполнение с автоматическим повтором ---

(defun выполнить-с-повтором (поток-функция задача макс-попыток)
  "Выполняет задачу с автоматическим повтором при ошибке.
   Возвращает результат или сообщение об ошибке после всех попыток."
  (let ((попытка 0))
    (labels ((попробовать ()
               (incf попытка)
               (handler-case
                   (funcall поток-функция задача)
                 (error (у)
                   (if (< попытка макс-попыток)
                       (попробовать)
                       (format nil "Ошибка после ~a попыток: ~a"
                               макс-попыток у))))))
      (попробовать))))

;;; --- сохранение и восстановление образа ---

(defun путь-образа (каталог имя)
  "Формирует путь к файлу образа."
  (merge-pathnames (format nil "~a.core" имя)
                   (make-pathname :directory
                     (append (pathname-directory каталог)
                             nil))))

(defun сохранить-образ (путь)
  "Сохраняет текущий образ SBCL в файл.
   После восстановления состояние потока сохраняется."
  (ensure-directories-exist путь)
  (sb-ext:save-lisp-and-die (namestring путь)
    :toplevel (lambda ()
                (format t "Образ восстановлен.~%")
                (sb-ext:exit :code 0))
    :purify t))

;;; --- запуск (для вызова из командной строки) ---

(defun запуск (путь-потока имя-пакета задача)
  "Загружает поток и выполняет задачу. Возвращает результат."
  (when (загрузить-поток путь-потока)
    (let ((функция (найти-точку-входа имя-пакета)))
      (if функция
          (progn
            (setf *текущий-поток-пакет* имя-пакета)
            (setf *текущий-поток-функция* функция)
            (выполнить-задачу функция задача))
          (format nil "Точка входа не найдена в пакете ~a" имя-пакета)))))
