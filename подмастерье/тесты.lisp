;;; -*- Mode: Lisp; Syntax: Common-Lisp -*-
;;; Тесты для исполнителя — загрузка потока, поиск точки входа, выполнение,
;;; повтор при ошибке, сохранение/восстановление образа

(load (merge-pathnames "подмастерье/исполнитель.lisp"
                       (make-pathname :directory '(:absolute "home" "tema" "development_system"))))

(defpackage :тесты
  (:use :cl :исполнитель))

(in-package :тесты)

(defvar *путь-потока*
  (merge-pathnames "мастер/потоки/эхо.lisp"
                   (make-pathname :directory '(:absolute "home" "tema" "development_system"))))

(defvar *путь-нет*
  (merge-pathnames "мастер/потоки/несуществует.lisp"
                   (make-pathname :directory '(:absolute "home" "tema" "development_system"))))

(defvar *каталог-образов*
  (merge-pathnames "мастер/образы/"
                   (make-pathname :directory '(:absolute "home" "tema" "development_system"))))

(defvar *число-тестов* 0)
(defvar *число-успехов* 0)

(defmacro тест (имя &body тело)
  `(progn
     (incf *число-тестов*)
     (handler-case
         (progn ,@тело
                (incf *число-успехов*)
                (format t "  + ~a~%" ,имя))
       (error (у)
         (format t "  ! ~a: ~a~%" ,имя у)))))

(defmacro проверить (выражение)
  `(unless ,выражение
     (error "Проверка не пройдена: ~s" ',выражение)))

;;; --- тесты загрузки ---

(format t "~%Тесты исполнителя:~%")

(тест "загрузить-поток: существующий файл"
  (проверить (eq t (загрузить-поток *путь-потока*))))

(тест "загрузить-поток: несуществующий файл"
  (handler-case
      (progn (загрузить-поток *путь-нет*)
             (error "Должна была быть ошибка"))
    (error (у)
      (проверить (search "не найден" (format nil "~a" у))))))

;;; --- тесты поиска точки входа ---

(тест "найти-точку-входа: существующий пакет"
  (let ((ф (найти-точку-входа "поток-эхо")))
    (проверить (not (null ф)))
    (проверить (functionp ф))))

(тест "найти-точку-входа: несуществующий пакет"
  (проверить (null (найти-точку-входа "нет-такого-пакета"))))

;;; --- тесты выполнения задачи ---

(тест "выполнить-задачу: нормальное выполнение"
  (let* ((ф (найти-точку-входа "поток-эхо"))
         (результат (выполнить-задачу ф "привет")))
    (проверить (string= результат "Эхо: привет"))))

(тест "выполнить-задачу: обработка ошибки"
  (let ((результат (выполнить-задачу
                    (lambda (з) (error "сбой"))
                    "тест")))
    (проверить (search "Ошибка" результат))))

;;; --- тесты выполнения с повтором ---

(тест "выполнить-с-повтором: успех с первой попытки"
  (let* ((ф (найти-точку-входа "поток-эхо"))
         (результат (выполнить-с-повтором ф "тест" 3)))
    (проверить (string= результат "Эхо: тест"))))

(тест "выполнить-с-повтором: ошибка после всех попыток"
  (let ((счётчик 0))
    (let ((результат (выполнить-с-повтором
                      (lambda (з)
                        (incf счётчик)
                        (error "сбой ~a" счётчик))
                      "тест" 3)))
      (проверить (= счётчик 3))
      (проверить (search "после 3 попыток" результат)))))

(тест "выполнить-с-повтором: успех со второй попытки"
  (let ((счётчик 0))
    (let ((результат (выполнить-с-повтором
                      (lambda (з)
                        (incf счётчик)
                        (if (= счётчик 1)
                            (error "временный сбой")
                            (format nil "Готово: ~a" з)))
                      "задача" 3)))
      (проверить (= счётчик 2))
      (проверить (string= результат "Готово: задача")))))

;;; --- тесты состояния ---

(тест "текущий-поток-пакет: начальное значение nil"
  (проверить (null (текущий-поток-пакет))))

;;; --- тест полного цикла ---

(тест "запуск: полный цикл загрузка-выполнение"
  (let ((результат (запуск *путь-потока* "поток-эхо" "мир")))
    (проверить (string= результат "Эхо: мир"))))

(тест "запуск: сохраняет имя пакета"
  (запуск *путь-потока* "поток-эхо" "тест")
  (проверить (string= (текущий-поток-пакет) "поток-эхо")))

;;; --- тест пути образа ---

(тест "путь-образа: формирование пути"
  (let ((п (путь-образа *каталог-образов* "эхо")))
    (проверить (search "эхо.core" (namestring п)))))

;;; --- итог ---

(format t "~%Итого: ~a/~a тестов пройдено.~%" *число-успехов* *число-тестов*)

(if (= *число-успехов* *число-тестов*)
    (format t "Все тесты пройдены.~%")
    (progn
      (format t "ЕСТЬ ОШИБКИ!~%")
      (sb-ext:exit :code 1)))

(sb-ext:exit :code 0)
