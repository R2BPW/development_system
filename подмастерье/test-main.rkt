#lang racket/base

;;; Тесты для Подмастерья — разбор обновлений, формирование ответов, SBCL-вызов

(require rackunit
         json
         racket/list
         racket/path
         racket/runtime-path
         racket/string
         "main.rkt")

(define-runtime-path корень "..")

;; --- тесты разбора обновлений ---

(test-case "разобрать-обновления-п: корректный ответ"
  (let* ((данные (jsexpr->string
                  (hash 'ok #t
                        'result (list
                                 (hash 'update_id 1
                                       'message
                                       (hash 'chat (hash 'id 42)
                                             'text "задача"))))))
         (результат (разобрать-обновления-п данные)))
    (check-equal? (length результат) 1)
    (check-true (hash? (car результат)))))

(test-case "разобрать-обновления-п: некорректный JSON"
  (check-equal? (разобрать-обновления-п "не json") '()))

(test-case "разобрать-обновления-п: ok=false"
  (let ((данные (jsexpr->string (hash 'ok #f 'result '()))))
    (check-equal? (разобрать-обновления-п данные) '())))

(test-case "разобрать-обновления-п: пустой результат"
  (let ((данные (jsexpr->string (hash 'ok #t 'result '()))))
    (check-equal? (разобрать-обновления-п данные) '())))

;; --- тесты извлечения сообщений ---

(test-case "извлечь-сообщения-п: одно сообщение"
  (let* ((обновления (list (hash 'update_id 5
                                 'message (hash 'chat (hash 'id 99)
                                                'text "привет"))))
         (сообщения (извлечь-сообщения-п обновления)))
    (check-equal? (length сообщения) 1)
    (check-equal? (first (car сообщения)) 5)
    (check-equal? (second (car сообщения)) 99)
    (check-equal? (third (car сообщения)) "привет")))

(test-case "извлечь-сообщения-п: обновление без message"
  (let ((обновления (list (hash 'update_id 1))))
    (check-equal? (извлечь-сообщения-п обновления) '())))

(test-case "извлечь-сообщения-п: несколько сообщений"
  (let* ((обновления (list (hash 'update_id 1
                                 'message (hash 'chat (hash 'id 10)
                                                'text "раз"))
                           (hash 'update_id 2
                                 'message (hash 'chat (hash 'id 20)
                                                'text "два"))))
         (сообщения (извлечь-сообщения-п обновления)))
    (check-equal? (length сообщения) 2)
    (check-equal? (third (first сообщения)) "раз")
    (check-equal? (third (second сообщения)) "два")))

;; --- тесты формирования ответа ---

(test-case "сформировать-ответ-подмастерье: /состояние без потока"
  (parameterize ([текущий-поток #f])
    (check-equal? (сформировать-ответ-подмастерье "/состояние")
                  "Поток не загружен.")))

(test-case "сформировать-ответ-подмастерье: /состояние с потоком"
  (parameterize ([текущий-поток
                  (list (build-path корень "мастер" "потоки" "эхо.lisp")
                        "поток-эхо")])
    (let ((ответ (сформировать-ответ-подмастерье "/состояние")))
      (check-true (string-contains? ответ "поток-эхо"))
      (check-true (string-contains? ответ "эхо.lisp")))))

(test-case "сформировать-ответ-подмастерье: задача без потока"
  (parameterize ([текущий-поток #f])
    (check-equal? (сформировать-ответ-подмастерье "сделай что-нибудь")
                  "Поток не загружен. Мастер должен назначить задачу.")))

;; --- тесты загрузки потока ---

(test-case "загрузить-поток-п: установка текущего потока"
  (parameterize ([текущий-поток #f])
    (загрузить-поток-п (build-path корень "мастер" "потоки" "эхо.lisp") "поток-эхо")
    (let ((п (текущий-поток)))
      (check-true (list? п))
      (check-equal? (second п) "поток-эхо"))))

;; --- тесты выполнения в SBCL ---

(test-case "выполнить-в-sbcl: эхо-поток"
  (parameterize ([путь-исполнителя
                  (build-path корень "подмастерье" "исполнитель.lisp")])
    (let ((результат (выполнить-в-sbcl
                      (build-path корень "мастер" "потоки" "эхо.lisp")
                      "поток-эхо"
                      "тестовая задача")))
      (check-true (string-contains? результат "Эхо: тестовая задача")))))

(test-case "выполнить-в-sbcl: несуществующий поток"
  (parameterize ([путь-исполнителя
                  (build-path корень "подмастерье" "исполнитель.lisp")])
    (let ((результат (выполнить-в-sbcl
                      (build-path корень "мастер" "потоки" "нет-такого.lisp")
                      "поток-нет"
                      "задача")))
      (check-true (string-contains? результат "Ошибка")))))

;; --- тест полного цикла задача-поток-ответ ---

(test-case "полный цикл: загрузка потока и выполнение задачи"
  (parameterize ([текущий-поток #f]
                 [путь-исполнителя
                  (build-path корень "подмастерье" "исполнитель.lisp")])
    (загрузить-поток-п
     (build-path корень "мастер" "потоки" "эхо.lisp")
     "поток-эхо")
    (let ((результат (сформировать-ответ-подмастерье "привет мир")))
      (check-true (string-contains? результат "Эхо: привет мир")))))

(displayln "Все тесты Подмастерья пройдены.")
